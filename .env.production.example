# Copy to .env.production on the production SWAS before starting
# docker-compose.tight.yml. Real values must NEVER be committed —
# gitleaks pre-commit hook will block.
#
# Per ADR-0026 § A-Tight v2 资源复用: mono = drop-in replacement of
# meta-server. 复用 meta SSH key / ACR creds / OSS bucket / Resend /
# domain api.xiaocaishen.me — 0 new infrastructure provisioning.

# === Image version ===
# Default `latest` follows main; pin to release tag (e.g. server-v0.1.5 →
# image tag v0.1.5 after build-image.yml strips server- prefix) for prod.
MBW_VERSION=latest

# Override for local dry-run with a locally-built image:
#   docker build -t nvy-server:dev -f apps/server/Dockerfile .
# MBW_APP_IMAGE=nvy-server:dev

# === App ===
# pino log level: trace | debug | info | warn | error | fatal (default info)
LOG_LEVEL=info

# CORS allow-list (per apps/server/src/config/app.config.ts).
# Production recommended (Cloudflare Pages host per ADR-0025):
CORS_ALLOWED_ORIGINS=https://app.xiaocaishen.me,https://no-vain-years-mono.pages.dev

# === DB / Redis credentials (single-node SWAS, docker network resolves) ===
DB_USERNAME=mbw
DB_PASSWORD=
REDIS_PASSWORD=

# DATABASE_URL / REDIS_URL are auto-composed in docker-compose.tight.yml app
# environment block from DB_PASSWORD + REDIS_PASSWORD above; no need to set
# here unless overriding service hostname.

# === Auth secrets ===
# Generate each with: openssl rand -hex 32
AUTH_JWT_SECRET=
SMS_CODE_HMAC_SECRET=

# === SMS gateway (per apps/server/src/config/sms.config.ts; ADR-0013) ===
# 'mock' (default; M1.1 阶段) | 'aliyun' (营业执照 + 阿里云签名审核通过后启用)
SMS_GATEWAY=mock

# When SMS_GATEWAY=aliyun, all 4 below required (Zod throws at boot otherwise).
# Leave blank for mock mode.
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=

# === WeChat 账号绑定 (per apps/server/src/config/wechat.config.ts; 010) ===
# Phase 1 仅 mock stub(dev/test)。生产 boot 拒 mock 且 real 未实现(Phase 2/T029) →
# wechat 绑定在 Phase 2 落地前不可用于生产,prod 此处保持注释、勿设。
# WECHAT_GATEWAY=real     # Phase 2 启用,并填下面两个
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# === Resend email (placeholder; ADR-0026 § A-Tight v2 继承复用 meta) ===
# mono M1.1 阶段不主动发 email (per ADR-0026)，但 secret 配置就位
# 复用 meta RESEND_API_KEY + sender@xiaocaishen.me (DKIM/SPF 已配)
# 当 M2+ 邮箱 use case 需要时启用，apps/server 加 EmailModule 消费这些 env
# RESEND_API_KEY=
# RESEND_BASE_URL=https://api.resend.com

# === Aliyun OSS — 头像/背景图直传 (per apps/server/src/config/oss.config.ts; ADR-0045) ===
# 账号 B (mbw-server-xt) 的 AK，与上面 SMS 的 ALIYUN_*(账号 A) 不同账号、并存。
# All-or-nothing presence gate: 4 个全填 → 启用 PostObject 直传签名;
# 全空/全注释 → unconfigured(上传端点返回 503,不崩);部分填 → Zod boot 抛错。
# region/bucket 已固定如下,启用时取消注释并填账号 B mbw-server-xt 的 AK 一对即可。
# 获取/provision 步骤见 docs/plans/2026-05/05-31-oss-provisioning-runbook.md § Step 5。
# OSS_REGION=oss-cn-shanghai
# OSS_BUCKET=mbw-profile-images
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# 自定义域名显示基址 — 备案下号 + OSS 绑定 img.shintongtech.com 后启用,浏览器才能内联预览;
# 未设则回退默认域名(内地 bucket 被强制下载,web <img> 坏)。步骤见
# docs/plans/2026-06/06-01-oss-custom-domain-binding-runbook.md
# OSS_PUBLIC_BASE_URL=https://img.shintongtech.com
