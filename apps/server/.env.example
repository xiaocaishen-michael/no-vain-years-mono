# Copy this file to .env (gitignored) and fill in real values for local dev.
# Spec for required env vars; checked into git for new-dev onboarding.
# All values parsed by Zod at boot (apps/server/src/config/*.config.ts) —
# missing or malformed → boot fails before listen.

# --- App ---
# 'development' | 'test' | 'production' (defaults to development)
NODE_ENV="development"
# Listen port (1–65535, default 3000)
PORT="3000"
# pino log level: trace | debug | info | warn | error | fatal (default info)
LOG_LEVEL="info"
# CORS allow-list. '*' = permissive (dev only); 'https://a.com,https://b.com' = strict.
# Empty / unset → no Access-Control-Allow-Origin emitted (lock-down).
# Production recommended (Cloudflare Pages host per ADR-0025;
# see docs/experience/2026-05/05-22-cloudflare-pages-deploy-mono.md):
#   CORS_ALLOWED_ORIGINS="https://app.xiaocaishen.me,https://no-vain-years-mono.pages.dev"
# Preview branch wildcards (*.no-vain-years-mono.pages.dev) currently NOT
# supported — parseOrigins handles literal strings only. Add specific preview
# origins on demand, or extend parseOrigins to recognize regex when needed.
CORS_ALLOWED_ORIGINS="*"

# --- Datastore ---
# PostgreSQL: docker-compose.dev.yml mbw-poc-postgres (port 5433).
DATABASE_URL="postgresql://mbw:mbw@localhost:5433/mbw_poc"

# Redis: docker-compose.dev.yml mbw-poc-redis (port 6380).
REDIS_URL="redis://localhost:6380"

# --- Auth secrets ---
# JWT HS256 secret — min 32 bytes. Replace via secrets manager in prod.
AUTH_JWT_SECRET="dev-only-secret-for-phone-sms-auth-32B-pad-xyzabc"

# SMS code HMAC-SHA256 secret — per ADR-0023, min 32 bytes. Replace via
# secrets manager in prod. Rotation policy: deprecation window ≥ 5min TTL
# so old-hash verify naturally expires before new-secret-only verify takes over.
SMS_CODE_HMAC_SECRET="dev-only-hmac-secret-for-sms-code-32B-zzzzzz"

# --- SMS gateway ---
# 'mock' (default; dev/test) | 'aliyun' (prod). When 'aliyun', all 4 ALIYUN_*
# values below are required and validated at boot (sms.config.ts).
SMS_GATEWAY="mock"
# When SMS_GATEWAY=aliyun these 4 are required (Zod throws at boot otherwise).
# Leave blank for mock mode.
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""
# Optional dedicated templates for 注销 / 撤销注销 codes (FR-S05/S08, 004).
# Blank → AliyunSmsGateway falls back to ALIYUN_SMS_TEMPLATE_CODE (login template).
ALIYUN_SMS_TEMPLATE_CODE_DELETE_ACCOUNT=""
ALIYUN_SMS_TEMPLATE_CODE_CANCEL_DELETION=""

# --- WeChat account binding (per apps/server/src/config/wechat.config.ts; 010) ---
# 'mock' (default; Phase 1 port-stub) | 'real' (Phase 2 OAuth). prod forbids mock.
WECHAT_GATEWAY="mock"
# When WECHAT_GATEWAY=real these 2 are required (Zod throws at boot otherwise).
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# --- IP geolocation (ip2region) ---
# Optional override for the ip2region .xdb data file path. Blank → resolveXdbPath()
# falls back to the bundled candidate paths (src/security/data | dist/security/data).
IP2REGION_XDB_PATH=""

# --- Object storage (Aliyun OSS — 009 profile image upload, per ADR-0045/0037) ---
# All-or-nothing: leave all four blank in dev/test → oss.config kind='unconfigured'
# (boot stays green, credential issuance unavailable). Set all four to enable.
# Creds = Aliyun *account B* (mbw-server-xt), minimal oss:PutObject on
# avatar/ + background/ prefixes — a different account than the SMS ALIYUN_* (A).
# Provisioning + deploy injection: docs/plans/2026-05/05-31-oss-provisioning-runbook.md
# OSS_REGION is endpoint-form incl. the oss- prefix (e.g. oss-cn-shanghai).
OSS_REGION="oss-cn-shanghai"
OSS_BUCKET="mbw-profile-images"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
# Optional custom-domain display base, e.g. https://img.shintongtech.com.
# When set, stored avatar/background URLs use it instead of the default OSS
# endpoint — bypasses Aliyun's 内地-bucket default-domain force-download (which
# breaks browser inline <img>). Empty → fallback to the aliyuncs endpoint.
# Requires the domain be ICP-备案'd + bound to the bucket; until then leave empty.
# See docs/plans/2026-06/06-01-oss-custom-domain-binding-runbook.md.
OSS_PUBLIC_BASE_URL=""
