generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["account", "public"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Account {
  id                BigInt       @id @default(autoincrement())
  phone             String?      @unique(map: "uk_account_phone") @db.VarChar(20)
  status            String       @db.VarChar(16)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  lastLoginAt       DateTime?    @map("last_login_at") @db.Timestamptz(6)
  displayName       String?      @map("display_name") @db.VarChar(64)
  bio               String?      @map("bio") @db.VarChar(120)
  gender            String?      @map("gender") @db.VarChar(16)
  freezeUntil       DateTime?    @map("freeze_until") @db.Timestamptz(6)
  previousPhoneHash String?      @map("previous_phone_hash") @db.VarChar(64)
  credentials       Credential[]

  @@index([freezeUntil], map: "idx_account_freeze_until_active", where: raw("(((status)::text = 'FROZEN'::text) AND (freeze_until IS NOT NULL))"))
  @@index([previousPhoneHash], map: "idx_account_previous_phone_hash", where: raw("(previous_phone_hash IS NOT NULL)"))
  @@map("account")
  @@schema("account")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model AccountSmsCode {
  id        BigInt    @id @default(autoincrement())
  accountId BigInt    @map("account_id")
  codeHash  String    @map("code_hash") @db.VarChar(64)
  purpose   String    @db.VarChar(32)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId, purpose], map: "idx_account_sms_code_account_purpose_active", where: raw("(used_at IS NULL)"))
  @@map("account_sms_code")
  @@schema("account")
}

// 010 微信账号绑定。贫血 row + @map (ADR-0043); 无声明 FK relation (同 AccountSmsCode)。
// openid 全局唯一 = FR-S01 冲突闸; (accountId, provider) 唯一 = O7 幂等 + R2 对称冲突闸。
// 注: 不另设 @@index([accountId]) —— (accountId, provider) 复合唯一索引按最左前缀
// 已覆盖所有 WHERE accountId / WHERE accountId AND provider 查询 (inspect/unbind), 独立索引冗余。
model WechatBinding {
  id        BigInt   @id @default(autoincrement())
  accountId BigInt   @map("account_id")
  provider  String   @default("WECHAT") @db.VarChar(16)
  openid    String   @unique(map: "uk_wechat_binding_openid") @db.VarChar(64)
  unionid   String?  @db.VarChar(64)
  boundAt   DateTime @default(now()) @map("bound_at") @db.Timestamptz(6)

  @@unique([accountId, provider], map: "uk_wechat_binding_account_provider")
  @@map("wechat_binding")
  @@schema("account")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Credential {
  id           BigInt    @id @default(autoincrement())
  accountId    BigInt    @map("account_id")
  type         String    @db.VarChar(16)
  passwordHash String?   @map("password_hash") @db.VarChar(60)
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  account      Account   @relation(fields: [accountId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([accountId, type], map: "uk_credential_account_type")
  @@index([accountId], map: "idx_credential_account_id")
  @@map("credential")
  @@schema("account")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model RefreshToken {
  id          BigInt    @id @default(autoincrement())
  tokenHash   String    @unique(map: "uk_refresh_token_token_hash") @map("token_hash") @db.VarChar(64)
  accountId   BigInt    @map("account_id")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deviceId    String    @map("device_id") @db.VarChar(36)
  deviceName  String?   @map("device_name") @db.VarChar(64)
  deviceType  String    @default("UNKNOWN") @map("device_type") @db.VarChar(16)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  loginMethod String    @default("PHONE_SMS") @map("login_method") @db.VarChar(16)

  @@index([accountId, deviceId], map: "idx_refresh_token_account_device_active", where: raw("(revoked_at IS NULL)"))
  @@index([accountId], map: "idx_refresh_token_account_id_active", where: raw("(revoked_at IS NULL)"))
  @@map("refresh_token")
  @@schema("account")
}

model OutboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  eventType   String    @map("event_type")
  payload     Json
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt], map: "outbox_event_unpublished_idx")
  @@map("outbox_event")
  @@schema("public")
}
