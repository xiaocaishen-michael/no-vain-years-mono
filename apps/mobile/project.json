{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile",
  "projectType": "application",
  "tags": ["scope:mobile-app"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "apps/mobile"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --max-warnings=0",
        "cwd": "apps/mobile"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --reporter=default",
        "cwd": "apps/mobile"
      }
    },
    "test:watch": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest",
        "cwd": "apps/mobile"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "expo start",
        "cwd": "apps/mobile"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "expo export -p web",
        "cwd": "apps/mobile"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/playwright-report", "{projectRoot}/playwright-test-results"],
      "options": {
        "command": "playwright test",
        "cwd": "apps/mobile"
      }
    },
    "runtime-smoke": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/playwright-report",
        "{projectRoot}/playwright-test-results"
      ],
      "options": {
        "command": "npx expo export -p web && pnpm exec playwright test -c playwright.runtime-smoke.config.ts",
        "cwd": "apps/mobile"
      }
    }
  }
}
