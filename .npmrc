# pnpm hoist policy.
#
# shamefully-hoist=true hoists all transitive dependencies to the workspace
# root node_modules. This trades strict isolation for compatibility with
# Metro / Expo / React Native Web, whose webpack-style resolution expects
# all peers (including deeply transitive ones like fbjs/invariant/styleq/
# react-fast-compare/...) reachable from the root tree.
#
# Why this is needed:
# - Initial attempt: pnpm{publicHoistPattern:[...]} in root package.json
#   (camelCase) is silently no-op'd by pnpm 10 — confirmed by `find
#   node_modules/fbjs` empty after `pnpm install`.
# - Second attempt: .npmrc public-hoist-pattern[] kebab-case correctly
#   hoists the listed patterns, but each `expo export -p web` cycle
#   surfaces another deeply transitive peer (fbjs → styleq → invariant
#   → react-fast-compare → ...), turning every mobile bootstrap into a
#   whack-a-mole.
# - Final: shamefully-hoist=true makes the root node_modules flat (like
#   yarn classic / npm), satisfying Metro's expectations in one shot.
#
# Trade-off: any package can import any transitive without declaring it,
# losing pnpm's "you only see what you declared" property. For a mono
# managed by ESLint @nx/enforce-module-boundaries (declared deps gate
# at lint level) and TypeScript path mappings (workspace-internal imports),
# the safety net at the import boundary is already there — pnpm-level
# isolation is redundant.
shamefully-hoist=true
